{
	"luci-app-streamlit-forge": {
		"description": "Grant access to Streamlit Forge",
		"read": {
			"ubus": {
				"luci.streamlit-forge": ["list", "status", "gitea_status", "info", "templates", "config", "nfo_read", "nfo_validate"]
			},
			"uci": ["streamlit-forge", "gitea"]
		},
		"write": {
			"ubus": {
				"luci.streamlit-forge": ["create", "delete", "start", "stop", "restart", "expose", "hide", "publish", "unpublish", "set_config", "edit", "pull", "push", "preview", "nfo_write"]
			},
			"uci": ["streamlit-forge"]
		}
	}
}
